<Project Sdk="Microsoft.NET.Sdk.WindowsDesktop">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <AssemblyName>LTDHelper</AssemblyName>
    <RootNamespace>LTDHelper</RootNamespace>
    <Version>2.0.0</Version>
    <Authors>Bastiian787</Authors>
    <Description>Limited Auto-Buyer for Habbo using G-Earth/Geode</Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="G-Earth-Geode" Version="1.4.1-beta" />
    <PackageReference Include="Serilog" Version="3.1.1" />
    <PackageReference Include="Serilog.Sinks.Console" Version="5.0.1" />
  </ItemGroup>

</Project>
