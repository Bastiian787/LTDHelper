<Window x:Class="LTDHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LTDHelper - Limited Auto Buyer"
        Height="480"
        Width="440"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="LTDHelper"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#222222"
                       HorizontalAlignment="Center"/>
            <Label x:Name="StatusLabel"
                   Content="Waiting for G-Earth connection…"
                   FontSize="11"
                   Foreground="#888888"
                   HorizontalAlignment="Center"
                   Padding="0,2,0,0"/>
        </StackPanel>

        <!-- Control buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,8">
            <Button x:Name="StartButton"
                    Content="Start"
                    Click="StartButton_Click"
                    Width="72" Height="28" Margin="4,0"
                    IsEnabled="False"
                    Background="#4CAF50" Foreground="White" FontSize="12"/>
            <Button x:Name="StopButton"
                    Content="Stop"
                    Click="StopButton_Click"
                    Width="72" Height="28" Margin="4,0"
                    IsEnabled="False"
                    Background="#F44336" Foreground="White" FontSize="12"/>
            <Button x:Name="ForceButton"
                    Content="Force"
                    Click="ForceButton_Click"
                    Width="72" Height="28" Margin="4,0"
                    IsEnabled="False"
                    Background="#FF9800" Foreground="White" FontSize="12"/>
            <Button x:Name="TestButton"
                    Content="Test"
                    Click="TestButton_Click"
                    Width="72" Height="28" Margin="4,0"
                    IsEnabled="False"
                    Background="#2196F3" Foreground="White" FontSize="12"/>
            <Button Content="Close"
                    Click="CloseButton_Click"
                    Width="72" Height="28" Margin="4,0"
                    Background="#9E9E9E" Foreground="White" FontSize="12"/>
        </StackPanel>

        <!-- Log output -->
        <Border Grid.Row="2"
                BorderBrush="#CCCCCC"
                BorderThickness="1"
                CornerRadius="3"
                Background="White">
            <TextBox x:Name="LogBox"
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     BorderThickness="0"
                     FontFamily="Consolas"
                     FontSize="11"
                     Padding="6"
                     Background="Transparent"/>
        </Border>

        <!-- Footer note -->
        <TextBlock Grid.Row="3"
                   Text="Use buttons above to control the auto-buyer. Requires G-Earth to be running."
                   FontSize="10"
                   Foreground="#AAAAAA"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,6,0,0"/>
    </Grid>
</Window>
